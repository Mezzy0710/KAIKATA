{
  "manifest_version": 3,
  "name": "CartForge - Cardmarket Cart Extractor",
  "version": "1.0.0",
  "description": "Extract your Cardmarket shopping cart for optimization with CartForge. Intelligently captures seller info, items, prices, and shipping details.",
  "author": "CartForge Contributors",
  "homepage_url": "https://github.com/Mezzy0710/cardmarket-cart-optimizer",

  "permissions": [
    "storage",
    "scripting",
    "clipboardWrite"
  ],

  "host_permissions": [
    "https://www.cardmarket.com/*",
    "https://cardmarket.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://www.cardmarket.com/*/Magic/Products/Sell",
        "https://www.cardmarket.com/*/Magic/Cart",
        "https://cardmarket.com/*/Magic/Products/Sell",
        "https://cardmarket.com/*/Magic/Cart"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Extract CartForge Cart",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["popup.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
