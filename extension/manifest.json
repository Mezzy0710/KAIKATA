{
  "manifest_version": 3,
  "name": "CartForge Cardmarket Extractor",
  "description": "Extracts structured shopping-cart data from Cardmarket and opens it in CartForge.",
  "version": "0.2.1",
  "permissions": ["activeTab", "clipboardWrite", "storage"],
  "host_permissions": [
    "https://www.cardmarket.com/*",
    "https://*.cardmarket.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mezzy0710.github.io/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["cartforge-bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.cardmarket.com/*/ShoppingCart*",
        "https://www.cardmarket.com/*/*/ShoppingCart*",
        "https://*.cardmarket.com/*/ShoppingCart*",
        "https://*.cardmarket.com/*/*/ShoppingCart*"
      ],
      "exclude_matches": [
        "https://www.cardmarket.com/*/ShoppingCart/Checkout/*",
        "https://*.cardmarket.com/*/ShoppingCart/Checkout/*",
        "https://www.cardmarket.com/*/*/ShoppingCart/Checkout/*",
        "https://*.cardmarket.com/*/*/ShoppingCart/Checkout/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
